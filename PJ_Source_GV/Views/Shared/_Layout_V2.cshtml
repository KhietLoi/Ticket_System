    <!-- Menu Search Helper - Cho phép trigger search từ bất kỳ đâu -->
    <script>
        // Initialize click handlers cho các link có data-search-keyword
        // Note: triggerMenuSearch function sẽ được định nghĩa trong menu-search.js
        $(document).ready(function() {
            // Xử lý click trên các link có data-search-keyword
            $(document).on('click', '[data-search-keyword]', function(e) {
                e.preventDefault();
                const keyword = $(this).data('search-keyword');
                if (keyword) {
                    // Nếu function triggerMenuSearch đã được định nghĩa (từ menu-search.js), dùng nó
                    // Nếu chưa, fallback về redirect
                    if (typeof window.triggerMenuSearch === 'function') {
                        window.triggerMenuSearch(keyword);
                    } else {
                        const searchUrl = '/MenuSearch?q=' + encodeURIComponent(keyword.trim());
                        window.location.href = searchUrl;
                    }
                }
            });

            // Xử lý click trên các link có class trigger-menu-search
            $(document).on('click', 'a.trigger-menu-search', function(e) {
                e.preventDefault();
                const keyword = $(this).text().trim() || $(this).data('keyword') || $(this).attr('title');
                if (keyword) {
                    // Nếu function triggerMenuSearch đã được định nghĩa (từ menu-search.js), dùng nó
                    // Nếu chưa, fallback về redirect
                    if (typeof window.triggerMenuSearch === 'function') {
                        window.triggerMenuSearch(keyword);
                    } else {
                        const searchUrl = '/MenuSearch?q=' + encodeURIComponent(keyword.trim());
                        window.location.href = searchUrl;
                    }
                }
            });
        });
    </script>
