@* @RenderSection("Scripts", required: false) *@

<script type="text/javascript">

    $(document).ready(function () {

        //set active item menu
        let locationPage = window.location.pathname.split('/');
        locationPage = locationPage.map(str => str.toLowerCase());

        if (locationPage[1]) {
            if (locationPage.length > 2) {
                $(`li[data-link='${locationPage[1]}']`).addClass('menu-item-open menu-item-here');

                if ($(`li[data-link='${locationPage[2]}']`).length == 0) {
                    $(`li[class='menu-item']`).each(function () {
                        if ($(this).data("link") && $(this).data("link").length > 0) {
                            let listTrang = $(this).data("link").split(",");
                            if (listTrang.includes(locationPage[2])) {
                                $(this).addClass('menu-item-active');
                            }
                        }
                    });
                } else {

                    $(`li[data-link='${locationPage[2]}']`).addClass('menu-item-active');
                }
            } else {
                $(`li[data-link='${locationPage[1]}']`).addClass('menu-item-active');

            }

        } else {
            $(`li[data-link='home']`).addClass('menu-item-active');
        }

        toastr.options = {
            "closeButton": false,
            "debug": false,
            "newestOnTop": false,
            "progressBar": false,
            "positionClass": "toast-bottom-right",
            "preventDuplicates": false,
            "onclick": null,
            "showDuration": "300",
            "hideDuration": "1000",
            "timeOut": "5000",
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "fadeIn",
            "hideMethod": "fadeOut"
        };

        //Hiện thông báo
        @if (TempData["Success"] != null)
        {
            <text>
                toastr.success('@Html.Raw(TempData["Success"].ToString().Replace("'", "\\'"))');
            </text>
        }

        @if (TempData["Error"] != null)
        {
           <text>
                toastr.error('@Html.Raw(TempData["Error"].ToString().Replace("'", "\\'"))');
           </text>
        }

        @if (TempData["Warning"] != null)
        {
            <text>
               toastr.warning('@Html.Raw(TempData["Warning"].ToString().Replace("'", "\\'"))');
            </text>
        }

        @if (User.IsInRole("chuyendoitk_view") || User.IsInRole("chuyendoitk_total") || User.IsInRole("admin"))
        {
            <text>
            $("#SelAccount").on("change", function () {
                var nhanVien = $(this).val();
                $.ajax({
                    url: "/Home/SetNhanVien",
                    type: "post",
                    data: { nhanVien },
                    success: function (result) {
                        if (result) {
                            toastr.success("Chuyển đổi thành công");
                            location.reload();
                        } else {
                            toastr.error("Chuyển đổi thành công");
                        }
                    },
                    error: function (e) {
                        toastr.error("ERROR SetNhanVien - Home: " + e.status + " - " + e.statusText);
                        KTApp.unblock('.blockui-loading', {});
                        if (e.status == 500 || e.status == 404) {
                            setTimeout(function () {
                                if (confirm("Bạn có muốn load lại trang và thử lại?")) {
                                    location.reload();
                                }
                            }, 2000);
                        }
                    }
                });
            });
            </text>
        }

        $("#selDonViFilters").on("change", function () {
            var maPhongBan = $(this).find('option:selected').val();
            $.ajax({
                url: "/Home/SetPhongBan",
                type: "post",
                data: {
                    maPhongBan
                },
                success: function (result) {
                    if (result) {
                        toastr.success("Cập nhật thành công");
                        location.reload();
                    } else {
                        toastr.error("Cập nhật thất bại");
                    }
                }
            });
        });
    });

    function ConvertDatetimeToString(text) {
        const dateStr = text,

            [yyyy, mm, dd, hh, mi] = dateStr.split(/[/:\-T]/)

        return `${dd}/${mm}/${yyyy}`;
    }

    @if (User.IsInRole("chuyendoitk_view") || User.IsInRole("chuyendoitk_total") || User.IsInRole("admin"))
    {
    <Text>

    function ChangeAccount() {
        $("#changeAccountModal").modal("show");
    }

    </Text>
    }


    function asideToggle() {
        $("#kt_brand p").hide("fast");
    }

</script>