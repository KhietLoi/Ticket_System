@{
    bool disabledMenu = ViewData["DisabledMenu"] != null;
    var identity = (ClaimsIdentity)User.Identity;
    string version = string.Format("{0:MMddHHmmss}", DateTime.Now);
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture?.UICulture?.Name ?? "vi";
    var isVietnamese = currentCulture == "vi";
}


@inject IHostingEnvironment hostingEnv

