@model List<PJ_Source_GV.Models.SupportTask>


@{
    ViewData["Title"] = "Support Task";
}

<div class="card card-custom">
    <!--HEADER-->
    <div class="card-header">
        <h3 class="card-title">Support Task</h3>
        <div class="card-toolbar">
            <a asp-action="Create" class="btn btn-primary btn-sm">
                Tạo tác vụ
            </a>
        </div>
    </div>

    <!--BODY-->
    <div class="card-body">
        <!--TABLE-->
        <table class="table table-striped table-hover" id="dt_task">
            <thead>
                <th>Task Name</th>
                <th>Department</th>
                <th>Main Staff</th>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="clickable-row"
                        data-href="@Url.Action("Detail", new { id = item.TaskId })"
                        
                        style ="cursor:pointer;">

                        <td>@item.TaskName</td>
                        <td>@item.DepartmentName</td>
                        <td>@item.StaffName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    #dt_task tbody tr:hover {
        background-color: #f3f6f9;
        transition: 0.2s;
    }
</style>

<script>
    $(document).ready(function () {
       $('#dt_task').DataTable({
            resposive: true
       });
       //click row -> redirect to details page
       $('#dt_task').on('click','.clickable-row', function(){
           window.location = $(this).data('href');
       });

       setTimeout(function() {
            var alert = $("#alertBox");
            if (alert.length) {
                alert.fadeOut("slow");
            }
        }, 3000);
    });

</script>

