@model PJ_Source_GV.Models.SupportDepartment

<div class="card card-custom">

    <!-- ===== HEADER ===== -->
    <div class="card-header">
        <h3 class="card-title">Department Detail</h3>
    </div>

    <!-- ===== FORM UPDATE ===== -->
    <form asp-action="Details" method="post">
        <div class="card-body">
            <!-- ALERT MESSAGE -->
            @if (TempData["Success"] != null)
            {
                <div id="alertMessage" class="alert alert-success fade show">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div id="alertMessage" class="alert alert-danger fade show">
                    @TempData["Error"]
                </div>
            }
            <input type="hidden" asp-for="DepartmentId" />

            <div class="alert alert-light-primary">
                Bạn có thể chỉnh sửa thông tin phòng ban tại đây.
            </div>

            <div class="form-group">
                <label asp-for="DepartmentCode"></label>
                <input asp-for="DepartmentCode" class="form-control" />
                <span asp-validation-for="DepartmentCode" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DepartmentName"></label>
                <input asp-for="DepartmentName" class="form-control" />
                <span asp-validation-for="DepartmentName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CreatedDate"></label>
                <input asp-for="CreatedDate"
                       type="date"
                       asp-format="{0:yyyy-MM-dd}"
                       class="form-control" />
            </div>

        </div>

        <div class="card-footer">
            <button type="submit" class="btn btn-success mr-2">Update</button>

            <button type="button"
                    class="btn btn-danger mr-2"
                    data-toggle="modal"
                    data-target="#deleteModal">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

<hr class="mt-8" />

<!-- ===== STAFF LIST ===== -->
<div class="card card-custom mt-5">

    <div class="card-header">
        <div class="card-title">
            <h3 class="card-label">
                Nhân viên thuộc phòng ban
                @if (Model.Staffs != null)
                {
                    <span class="badge badge-primary ml-2">
                        @Model.Staffs.Count
                    </span>
                }
            </h3>
        </div>

        <div class="card-toolbar">
            <a asp-controller="DepartmentStaff"
               asp-action="AddStaff"
               asp-route-departmentId="@Model.DepartmentId"
               class="btn btn-light-primary btn-sm">
                + Thêm nhân viên phụ trách
            </a>
        </div>
    </div>

    <div class="card-body p-0">

        @if (Model.Staffs != null && Model.Staffs.Any())
        {
            <div class="table-responsive">

                <table class="table table-hover table-striped mb-0">

                    <thead class="thead-light">
                        <tr>
                            <th>Họ tên</th>
                            <th>Email</th>
                            <th>Chức vụ</th>
                            <th style="width:120px">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var staff in Model.Staffs)
                        {
                            <tr class="staff-row"
                                data-url="@Url.Action("Details", "SupportStaff", new { id = staff.StaffId })"
                                style="cursor:pointer">

                                <td>@staff.FullName</td>
                                <td>@staff.Email</td>
                                <td>@staff.Position</td>

                                <td>
                                    <form asp-action="RemoveStaff"
                                          method="post"
                                          class="d-inline">

                                        <input type="hidden"
                                               name="departmentId"
                                               value="@Model.DepartmentId" />

                                        <input type="hidden"
                                               name="staffId"
                                               value="@staff.StaffId" />

                                        <button type="submit"
                                                class="btn btn-sm btn-danger"
                                                onclick="event.stopPropagation(); return confirm('Xóa nhân viên khỏi phòng ban này?')">
                                            Remove
                                        </button>
                                    </form>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>

                <!-- Pagination -->
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Details"
                                   asp-route-id="@Model.DepartmentId"
                                   asp-route-page="@i">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>

            </div>
        }
        else
        {
            <div class="p-5 text-center text-muted">
                Chưa có nhân viên nào trong phòng ban này.
            </div>
        }

    </div>
</div>

<!-- ===== DELETE MODAL ===== -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete this department?
            </div>

            <div class="modal-footer">

                <form asp-action="Delete" method="post">
                    <input type="hidden"
                           name="id"
                           value="@Model.DepartmentId" />
                    <button type="submit" class="btn btn-danger">
                        Yes, Delete
                    </button>
                </form>

                <button type="button"
                        class="btn btn-secondary"
                        data-dismiss="modal">
                    Cancel
                </button>

            </div>

        </div>
    </div>
</div>

<style>
    .staff-row:hover {
        background-color: #f5f7fa;
        transition: 0.2s;
    }
</style>

<script>
    // Click nguyên dòng -> mở tab mới
    $(document).on('click', '.staff-row', function (e) {

        if ($(e.target).closest('button, form').length > 0)
            return;

        var url = $(this).data('url');
        window.open(url, '_blank');
    });

    //HIỆN THÔNG BÁO:
    setTimeout(function () {
        var alert = document.getElementById("alertMessage");
        if (alert) {
            alert.style.transition = "opacity 0.5s ease";
            alert.style.opacity = "0";
            setTimeout(() => alert.remove(), 500);
        }
    }, 3000);

</script>