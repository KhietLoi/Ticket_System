@model List<PJ_Source_GV.Models.SupportDepartment>

@{
    ViewData["Title"] = "Support Department";
}

<div class="card card-custom">

    <!-- ===== HEADER ===== -->
    <div class="card-header">
        <h3 class="card-title">
            Support Department
        </h3>

        <div class="card-toolbar">
            <a asp-action="Create"
               class="btn btn-primary btn-sm">
                + Thêm mới
            </a>
        </div>
    </div>

    <!-- ===== BODY ===== -->
    <div class="card-body">

        <!-- SUCCESS MESSAGE -->
        @if (TempData["Success"] != null)
        {
            <div id="alertBox"
                 class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
            </div>
        }

        <!-- TABLE -->
        <table class="table table-striped table-hover"
               id="dt_department">

            <thead>
                <tr>
                    <th>Department Code</th>
                    <th>Department Name</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="clickable-row"
                        data-href="@Url.Action("Details", new { id = item.DepartmentId })"
                        style="cursor:pointer;">

                        <td>
                            @item.DepartmentCode
                        </td>

                        <td>
                            @item.DepartmentName
                        </td>

                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>

<style>
    #dt_department tbody tr:hover {
        background-color: #f3f6f9;
        transition: 0.2s;
    }
</style>

<script>
    $(document).ready(function () {

        $('#dt_department').DataTable({
            responsive: true
        });

        // Click row -> redirect to Details
        $('#dt_department').on('click', '.clickable-row', function () {
            window.location = $(this).data('href');
        });

        setTimeout(function () {
            var alert = $("#alertBox");
            if (alert.length) {
                alert.fadeOut("slow");
            }
        }, 3000);

    });
</script>