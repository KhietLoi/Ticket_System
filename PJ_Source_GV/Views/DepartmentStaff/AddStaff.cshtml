@model List<SupportStaff>

<div class="card card-custom">
    <div class="card-header">
        <h3 class="card-title">
            Add Staff To Department
        </h3>
    </div>

    <div class="card-body">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Current Departments</th>
                    <th width="120px">Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.CurrentDepartments</td>
                        
                        <td>
                            <button type="button"
                                    class="btn btn-sm btn-primary btn-add"
                                    data-toggle="modal"
                                    data-target="#confirmAddModal"
                                    data-staffid="@item.StaffId">
                                Add
                            </button>
                        </td>
                        
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>
<div class="modal fade" id="confirmAddModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Xác nhận thêm</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body">
                Bạn có chắc muốn thêm nhân viên này vào phòng ban?
            </div>

            <div class="modal-footer">
                <form id="confirmForm"
                      asp-controller="DepartmentStaff"
                      asp-action="AddStaffToDepartment"
                      method="post">

                    <input type="hidden" name="StaffId" id="modalStaffId" />
                    <input type="hidden"
                           name="DepartmentId"
                           value="@ViewBag.DepartmentId" />

                    <button type="submit" class="btn btn-primary">
                        Yes, Add
                    </button>
                </form>

                <button type="button"
                        class="btn btn-secondary"
                        data-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    $(document).ready(function () {

        $('#confirmAddModal').on('show.bs.modal', function (event) {

            var button = $(event.relatedTarget);
            var staffId = button.data('staffid');

            $('#modalStaffId').val(staffId);

        });

    });
</script>