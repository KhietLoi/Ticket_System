@model PJ_Source_GV.ViewModels.TicketDetailVM

<div class="card">
    <div class="card-header">
        <h3>Chi tiết yêu cầu</h3>
    </div>

    <div class="card-body">

        <p><b>Mã đơn:</b> @Model.TicketCode</p>

        <p><b>Phòng ban:</b> @Model.DepartmentName</p>

        <p><b>Loại yêu cầu:</b> @Model.TaskName</p>

        <p><b>Trạng thái:</b> @Model.Status</p>

      

        <p>
            <b>Dự kiến hoàn thành:</b>
            @(Model.ExpectedCompleteDate?.ToString("dd/MM/yyyy") ?? "Chưa xác định")
        </p>

        

        <p><b>Ngày tạo:</b> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</p>

        <hr />

        <p><b>Mô tả:</b></p>

        <div class="border p-3">
            @Model.Description
        </div>

        <hr />
        <hr />

        <h4>Trao đổi với bộ phận hỗ trợ</h4>

        <div id="chatBox"
             style="height:300px;
     overflow-y:auto;
     border:1px solid #ddd;
     padding:10px;
     background:#fafafa;">
        </div>

        <div class="mt-3 d-flex">

            <input id="txtMessage"
                   class="form-control"
                   placeholder="Nhập nội dung..." />

            <button type="button"
                    class="btn btn-primary ml-2"
                    onclick="sendMessage()">
                Gửi
            </button>

        </div>
        <h5>File đính kèm</h5>

        @if (Model.Attachment != null)
        {
            <div class="mt-3">

                <a href="@Model.Attachment.FilePath" target="_blank">
                    <img src="@Model.Attachment.FilePath"
                         class="img-fluid border rounded"
                         style="max-width:300px;" />
                </a>

                

            </div>
        }
        else
        {
            <p class="text-muted">Không có file đính kèm</p>
        }

        <br />

        <a href="/Ticket" class="btn btn-secondary">
            Quay lại
        </a>

    </div>
</div>

<script>

       function loadMessages() {

        $.get('/TicketMessage/GetMessages?ticketId=@Model.TicketId', function (data) {

            $("#chatBox").html("");

            data.forEach(function (msg) {

                let align = msg.isStaff ? "text-left" : "text-right";
                let color = msg.isStaff ? "#f8f9fa" : "#d1ecf1";

                $("#chatBox").append(`
                    <div style="margin-bottom:10px; text-align:${align}">
                        <div style="
                            display:inline-block;
                            background:${color};
                            padding:8px;
                            border-radius:10px;
                            max-width:60%">
                            <b>${msg.SenderName}</b><br/>
                            ${msg.Message}
                        </div>
                    </div>
                `);

            });

            $("#chatBox").scrollTop($("#chatBox")[0].scrollHeight);

        });

    }
        function sendMessage() {

        let message = $("#txtMessage").val();

        if (message.trim() == "") return;

        $.post('/TicketMessage/SendMessageUser',
        {
            TicketId: @Model.TicketId,
            Message: message,
            Email: "@Model.CreatedByEmail"
        },
        function () {

            $("#txtMessage").val("");

            loadMessages();

        });

    }
        $(document).ready(function () {

        loadMessages();

        setInterval(function () {

            loadMessages();

        }, 3000);

    });




</script>