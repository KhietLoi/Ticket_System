@model PJ_Source_GV.ViewModels.TicketManagerDetailVM

<style>
    .chat-toggle {
        background: #007bff;
        color: white;
        padding: 10px;
        cursor: pointer;
        border-radius: 5px;
        margin-top: 20px;
        font-weight: 600;
    }

    .chat-toggle:hover {
        background: #0056b3;
    }

    .ticket-comment {
        border-radius: 6px;
        padding: 12px;
        margin-bottom: 12px;
        border: 1px solid #ddd;
    }

    .staff-comment {
        background: #e7f3ff;
        border-left: 4px solid #007bff;
    }

    .user-comment {
        background: #f8f9fa;
        border-left: 4px solid #6c757d;
    }

    .comment-header {
        display: flex;
        justify-content: space-between;
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 6px;
    }

    .comment-user {
        color: #2c3e50;
    }

    .comment-time {
        color: #888;
        font-size: 12px;
    }

    .comment-body {
        font-size: 14px;
    }

</style>
<div class="card card-custom">
    <div class="card-header">
        <h3 class="card-title">Chi tiết Ticket</h3>
    </div>

    <form method="post" action="/Ticket/AssignStaff">
        <div class="card-body">

            <input type="hidden" name="ticketId" value="@Model.TicketId" />

            <!-- Ticket Code -->
            <div class="form-group">
                <label>Mã Ticket</label>
                <input class="form-control" value="@Model.TicketCode" readonly />
            </div>


            <!-- Email -->
            <div class="form-group">
                <label>Email người gửi</label>
                <input class="form-control" value="@Model.CreatedByEmail" readonly />
            </div>

            <!-- Description -->
            <div class="form-group">
                <label>Mô tả</label>
                <textarea class="form-control" rows="4" readonly>@Model.Description</textarea>
            </div>

            


            <!-- Status -->
            @* <div class="form-group">
                <label>Trạng thái</label>
                <select name="Status" class="form-control">

                    <option value="0" @(Model.Status == PJ_Source_GV.Enums.TicketStatus.Received ? "selected" : "")>
                        Đã tiếp nhận
                    </option>

                    <option value="1" @(Model.Status == PJ_Source_GV.Enums.TicketStatus.Processing ? "selected" : "")>
                        Đang xử lý
                    </option>

                    <option value="2" @(Model.Status == PJ_Source_GV.Enums.TicketStatus.Completed ? "selected" : "")>
                        Đã xử lý
                    </option>

                </select>
            </div> *@
            <input class="form-control"
                   value="@Model.Status"
                   readonly />

            <!-- Expected Complete -->
            <input type="date"
                   name="ExpectedCompleteDate"
                   class="form-control"
                   required
                   value="@(Model.ExpectedCompleteDate?.ToString("yyyy-MM-dd"))" />


            <div class="form-group">
                <label>Phân công người xử lý</label>

                @if (Model.AssignedToStaffId != null)
                {
                    var staff = ViewBag.AssignedStaff;

                    <input class="form-control"
                           value="@staff.FullName"
                           readonly />

                    <input type="hidden"
                           name="assignedStaffId"
                           value="@staff.StaffId" />
                }
                else
                {
                    <select name="assignedStaffId" class="form-control" required>

                        <option value="">-- Chọn Staff --</option>

                        @foreach (var staff in ViewBag.StaffList)
                        {
                            <option value="@staff.StaffId">
                                @staff.FullName
                            </option>
                        }

                    </select>
                }
            </div>
            <hr />

            
            <h5>File đính kèm</h5>

            @if (Model.Attachment != null)
            {
                <div class="mt-3">

                    <a href="@Model.Attachment.FilePath" target="_blank">
                        <img src="@Model.Attachment.FilePath"
                             class="img-fluid border rounded"
                             style="max-width:300px;" />
                    </a>



                </div>
            }
            else
            {
                <p class="text-muted">Không có file đính kèm</p>
            }

        </div>

        <div class="card-footer">

            <button type="submit" class="btn btn-primary">
                Lưu cập nhật
            </button>

            <a href="/Ticket/Delete/@Model.TicketId"
               class="btn btn-danger"
               onclick="return confirm('Bạn có chắc muốn xoá ticket này?')">
                Xóa
            </a>

            <a href="/Ticket/Index_Manager" class="btn btn-secondary">
                Quay lại
            </a>

        </div>
    </form>

    <!--Thêm phần thanh chat thu gọn-->
    <div class="chat-toggle" onclick="toggleChat()">
        💬 Trao đổi Ticket
    </div>
   

    <div id="chatPanel" style="display:none; border-top:1px solid #ddd; padding-top:15px;">

        <div id="chatBox"
             style="height:800px;
         overflow-y:auto;
         border:1px solid #ddd;
         padding:10px;
         background:#fafafa;">
        </div>

        <div class="mt-3 d-flex">

            <textarea id="txtMessage"
                      class="form-control"
                      rows="3"
                      placeholder="Nhập nội dung phản hồi..."></textarea>

            <input type="file"
                   id="fileUpload"
                   class="form-control ml-2"
                   multiple />

            <button type="button"
                    class="btn btn-primary ml-2"
                    onclick="sendMessage()">
                Gửi
            </button>



        </div>

    </div>
    @if (Model.Status == PJ_Source_GV.Enums.TicketStatus.Processing)
    {
        <button type="button"
                class="btn btn-success"
                data-toggle="modal"
                data-target="#confirmComplete">
            <i class="fa fa-check"></i>Đánh dấu hoàn thành
        </button>
    }

</div>

<div class="modal fade" id="confirmComplete" tabindex="-1">

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Xác nhận hoàn thành</h5>

                <button type="button"
                        class="close"
                        data-dismiss="modal">
                    &times;
                </button>
            </div>

            <div class="modal-body">
                Bạn có chắc muốn đánh dấu ticket này đã hoàn thành?
            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-dismiss="modal">
                    Hủy
                </button>

                <form method="post" action="/Ticket/CompleteTicket">

                    <input type="hidden"
                           name="ticketId"
                           value="@Model.TicketId" />

                    <button class="btn btn-success">
                        Xác nhận
                    </button>

                </form>

            </div>

        </div>
    </div>

</div>
<!--Load cdn cua signalR-->
<script src="https://cdnjs.cloudflare.com/ajax/libs/aspnet-signalr/1.0.0/signalr.min.js"></script>

<script>

    // tạo kết nối SignalR
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/tickethub")
        .build();


    // load danh sách tin nhắn
    function loadMessages() {

        $.get('/TicketMessage/GetMessages?ticketId=@Model.TicketId', function (data) {

            $("#chatBox").html("");

            data.forEach(function (msg) {

                let align = msg.IsStaff ? "right" : "left";
                let color = msg.IsStaff ? "#d1ecf1" : "#f8f9fa";

                let attachmentsHtml = "";

                if (msg.Attachments && msg.Attachments.length > 0) {

                    msg.Attachments.forEach(function(file){

                            let ext = file.FileName.split('.').pop().toLowerCase();

                            let imageExt = ["jpg","jpeg","png","gif","webp"];

                            if(imageExt.includes(ext)){

                                attachmentsHtml += `
                                    <div style="margin-top:5px">
                                        <img src="${file.FilePath}"
                                             style="max-width:200px; border-radius:6px; cursor:pointer"
                                             onclick="window.open('${file.FilePath}')"/>
                                    </div>
                                `;

                            }else{

                                attachmentsHtml += `
                                    <div style="margin-top:5px">
                                        📎 <a href="${file.FilePath}" target="_blank">
                                            ${file.FileName}
                                        </a>
                                    </div>
                                `;

                            }

                        });

                }

            $("#chatBox").append(`
                <div class="ticket-comment ${msg.IsStaff ? 'staff-comment' : 'user-comment'}">

                    <div class="comment-header">
                        <span class="comment-user">${msg.SenderName}</span>
                        <span class="comment-time">${msg.CreatedDate}</span>
                    </div>

                    <div class="comment-body">
                        ${msg.Message ?? ""}
                        ${attachmentsHtml}
                    </div>

                </div>
            `);

            });

            $("#chatBox").scrollTop($("#chatBox")[0].scrollHeight);

        });
    }


    // gửi message
    function sendMessage() {

        let message = $("#txtMessage").val();
        let files = $("#fileUpload")[0].files;

        if (message.trim() === "" && files.length === 0) return;

        let formData = new FormData();

        formData.append("TicketId", @Model.TicketId);
        formData.append("Message", message);

        for (let i = 0; i < files.length; i++) {
            formData.append("files", files[i]);
        }

        $.ajax({
            url: '/TicketMessage/SendMessage',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,

            success: function () {

                $("#txtMessage").val("");
                $("#fileUpload").val("");

                loadMessages();

            }
        });

    }


    // nhận message realtime
    connection.on("ReceiveMessage", function () {
        loadMessages();
    });


    // khi trang load
    $(document).ready(function () {

        loadMessages();

        connection.start()
            .then(function () {

                console.log("SignalR Connected");

                connection.invoke("JoinTicket", @Model.TicketId)
                    .catch(function (err) {
                        console.error(err.toString());
                    });

            })
            .catch(function (err) {
                console.error(err.toString());
            });

    });

    //Mở rộng chat:
        function toggleChat(){

        let panel = $("#chatPanel");

        if(panel.is(":visible")){
            panel.slideUp();
        }else{
            panel.slideDown();
            loadMessages();
        }

    }

</script>

