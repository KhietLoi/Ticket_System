@model List<PJ_Source_GV.ViewModels.TicketListVM>

@{
    ViewData["Title"] = "Danh sách đơn";
}

<div class="card card-custom">

    <!-- ===== HEADER ===== -->
    <div class="card-header">
        <h3 class="card-title">
            Danh sách đơn
        </h3>

        <div class="card-toolbar">
            <a asp-action="Create"
               class="btn btn-primary btn-sm">
                + Tạo mới
            </a>
        </div>
    </div>

    <!-- ===== BODY ===== -->
    <div class="card-body">

        @if (TempData["Success"] != null)
        {
            <div id="alertBox"
                 class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
            </div>
        }

        <!-- FILTER -->
        <select id="ticket_status_filter"
                class="form-control form-control-sm mb-3">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Đã tiếp nhận">Đã tiếp nhận</option>
            <option value="Đang xử lý">Đang xử lý</option>
            <option value="Đã xử lý">Đã xử lý</option>
        </select>

        <!-- ===== TABLE ===== -->
        <table class="table table-striped table-hover"
               id="dt_ticket">

            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Loại yêu cầu</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Dự kiến hoàn thành</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="ticket-row"
                        data-url="@Url.Action("Detail", "Ticket", new { id = item.TicketId })"
                        style="cursor:pointer">

                        <td>@item.TicketCode</td>
                        <td>@item.TaskName</td>
                       
                        <td>
                            @if (item.Status == PJ_Source_GV.Enums.TicketStatus.Received)
                            {
                                <span class="badge bg-primary">Received</span>
                            }
                            else if (item.Status == PJ_Source_GV.Enums.TicketStatus.Processing)
                            {
                                <span class="badge bg-warning">Processing</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                        </td>

                        <td>@item.CreatedDate?.ToString("dd/MM/yyyy")</td>
                        <td>@item.ExpectedCompleteDate?.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>

<style>
    #dt_ticket tbody tr.ticket-row:hover {
        background-color: #f5f7fa;
    }
</style>

<script>
    $(document).ready(function () {

        var table = $('#dt_ticket').DataTable({
            responsive: true,
            dom:
                "<'row mb-3'" +
                "<'col-md-4'l>" +
                "<'col-md-4 text-center'<'statusFilterHolder'>>" +
                "<'col-md-4 text-right'f>" +
                ">" +
                "rtip"
        });

        $('#ticket_status_filter')
            .appendTo('.statusFilterHolder')
            .addClass('d-inline-block')
            .css('width', '250px');

        // Filter theo trạng thái (cột 2)
        $('#ticket_status_filter').on('change', function () {
            table.column(2).search(this.value).draw();
        });

        setTimeout(function () {
            $("#alertBox").fadeOut("slow");
        }, 3000);
    });

    $(document).on('click', '#dt_ticket tbody tr.ticket-row', function () {
        var url = $(this).data('url');
        window.location.href = url;
    });
</script>