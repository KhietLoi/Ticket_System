@model List<PJ_Source_GV.Models.SupportStaff>

@{
    ViewData["Title"] = "Support Staff";
}

<div class="card card-custom">

    <!-- ===== HEADER ===== -->
    <div class="card-header">
        <h3 class="card-title">
            Support Staff
        </h3>

        <div class="card-toolbar">
            <a asp-action="Create"
               class="btn btn-primary btn-sm">
                + Thêm mới
            </a>
        </div>
    </div>

    <!-- ===== BODY ===== -->
    <div class="card-body">

        @if (TempData["Success"] != null)
        {
            <div id="alertBox"
                 class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
            </div>
        }

        <!-- FILTER -->
        <select id="staff_status_filter"
                class="form-control form-control-sm mb-3">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Hoạt động">Hoạt động</option>
            <option value="Không hoạt động">Không hoạt động</option>
        </select>

        <!-- ===== TABLE ===== -->
        <table class="table table-striped table-hover"
               id="dt_staff">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Position</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="staff-row"
                        data-url="@Url.Action("Details", "SupportStaff", new { id = item.StaffId })"
                        style="cursor:pointer">

                        <td>@item.StaffId</td>
                        <td>@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.Position</td>

                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge badge-success">
                                    Hoạt động
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-danger">
                                    Không hoạt động
                                </span>
                            }
                        </td>

                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>

<style>
    /* Hover sáng nguyên dòng */
    #dt_staff tbody tr.staff-row:hover {
        background-color: #f5f7fa;
    }
</style>

<script>
    $(document).ready(function () {

        var table = $('#dt_staff').DataTable({
            responsive: true,
            dom:
                "<'row mb-3'" +
                "<'col-md-4'l>" +
                "<'col-md-4 text-center'<'statusFilterHolder'>>" +
                "<'col-md-4 text-right'f>" +
                ">" +
                "rtip"
        });

        // Đưa dropdown filter lên giữa
        $('#staff_status_filter')
            .appendTo('.statusFilterHolder')
            .addClass('d-inline-block')
            .css('width', '250px');

        // Filter theo trạng thái
        $('#staff_status_filter').on('change', function () {
            table.column(4).search(this.value).draw();
        });

        // Auto ẩn thông báo
        setTimeout(function () {
            $("#alertBox").fadeOut("slow");
        }, 3000);

    });

    // Click nguyên dòng
    $(document).on('click', '#dt_staff tbody tr.staff-row', function () {
        var url = $(this).data('url');
        window.location.href = url;
    });
</script>