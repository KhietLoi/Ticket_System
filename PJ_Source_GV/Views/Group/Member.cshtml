@using PJ_Source_GV.Areas.API.Models
@using PJ_Source_GV.Services;
@using PJ_Source_GV.Caption
@using System.Security.Claims;
@using Microsoft.AspNetCore.Localization

@{
    ViewData["Title"] = "Quản lý thành viên nhóm: " + ViewData["group_name"];
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture?.UICulture?.Name ?? "vi";
    var isVietnamese = currentCulture == "vi";
}

<div class="row">
    <div class="col-xl-12">
        <div class="card card-custom gutter-b">
            <div class="card-header">
                <h4 class="card-title">
                    Quản lý thành viên nhóm: @ViewData["group_name"]
                </h4>
            </div>
            <!--begin::Form-->
            <div class="card-body">
                <div class="form-group row">

                    <form class="form">
                        <label class="col-form-label text-right col-lg-3 col-sm-12">Email</label>
                        <div class="col-lg-6 ">
                            <div class="form-group d-none">
                                <label>group id</label>
                                <input type="text" class="form-control hidden" id="group_id" name="id" value="@ViewData["group_id"]" />
                            </div>
                            <div class="input-group">
                                <input type="text" class="form-control" id="selMember" name="selMember" placeholder="Nhập email phân quyền" required />
                                <div class="input-group-append"><span class="input-group-text">@@tdtu.edu.vn</span></div>
                            </div>
                        </div>
                        <div class="col-lg-2">
                            <div data-repeater-create="" class="btn font-weight-bold btn-primary btnAdd">
                                <i class="la la-plus"></i>
                                Thêm
                            </div>
                        </div>

                    </form>
                </div>
                <div class="row">
                    <div class="card-body">
                        <div class="mb-3">
                            <button type="button" class="btn btn-success btn-sm" id="btnExportExcel">
                                Xuất Excel
                            </button>
                        </div>
                        <!--begin: Datatable-->
                        <table class="table table-striped table-condensed table-hover" id="dt_member">
                            <thead>
                                <tr>
                                    <th>Thao tác</th>
                                    <th>Mã nhân viên</th>
                                    <th>Tên nhân viên</th>
                                    <th>Mã Khoa</th>
                                    <th>Tên Khoa</th>
                                    <th>Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (NhanVienSVModel row in Model)
                                {
                                    if (User.IsInRole("admin"))
                                    {
                                        <tr>
                                            <td nowrap="nowrap">

                                                @if (User.IsInRole("admin"))
                                                {
                                                    <a class="btn btn-icon btn-sm btn-danger mr-2 confirm-delete" data-id="@row.Email" data-toggle="tooltip" title="Xóa">
                                                        <i class="flaticon2-trash"></i>
                                                    </a>
                                                }

                                            </td>
                                            <td>
                                                @row.MaNhanVien
                                            </td>
                                            <td>
                                                @row.Hoten
                                            </td>
                                            <td>
                                                @row.MaKhoa
                                            </td>
                                            <td>
                                                @row.TenBoPhan
                                            </td>
                                            <td>
                                                @row.Email
                                            </td>

                                        </tr>
                                    }

                                }

                            </tbody>
                            <tfoot>
                                <tr>
                                    <th></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="@(isVietnamese ? "Tìm kiếm..." : "Search...")" /></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="@(isVietnamese ? "Tìm kiếm..." : "Search...")" /></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="@(isVietnamese ? "Tìm kiếm..." : "Search...")" /></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="@(isVietnamese ? "Tìm kiếm..." : "Search...")" /></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="@(isVietnamese ? "Tìm kiếm..." : "Search...")" /></th>
                                </tr>
                            </tfoot>
                        </table>
                        <!--end: Datatable-->
                    </div>
                </div>
            </div>
            <!--end::Form-->
        </div>
    </div>
</div>



<script type="text/javascript">
    var table = null;
    $(document).ready(function () {
        var currentLang = '@currentCulture';
        var dtLanguage = currentLang === 'vi' ? {
            "sProcessing": "Đang xử lý...",
            "sLengthMenu": "Hiển thị _MENU_ dòng",
            "sZeroRecords": "Không tìm thấy dữ liệu",
            "sInfo": "Hiển thị _START_ đến _END_ trong tổng số _TOTAL_ dòng",
            "sInfoEmpty": "Hiển thị 0 đến 0 trong tổng số 0 dòng",
            "sInfoFiltered": "(được lọc từ _MAX_ dòng)",
            "sInfoPostFix": "",
            "sSearch": "Tìm kiếm:",
            "sUrl": "",
            "oPaginate": {
                "sFirst": "Đầu",
                "sPrevious": "Trước",
                "sNext": "Sau",
                "sLast": "Cuối"
            }
        } : {
            "sProcessing": "Processing...",
            "sLengthMenu": "Show _MENU_ entries",
            "sZeroRecords": "No matching records found",
            "sInfo": "Showing _START_ to _END_ of _TOTAL_ entries",
            "sInfoEmpty": "Showing 0 to 0 of 0 entries",
            "sInfoFiltered": "(filtered from _MAX_ total entries)",
            "sInfoPostFix": "",
            "sSearch": "Search:",
            "sUrl": "",
            "oPaginate": {
                "sFirst": "First",
                "sPrevious": "Previous",
                "sNext": "Next",
                "sLast": "Last"
            }
        };

        table = $('#dt_member').DataTable({
            language: dtLanguage,
            responsive: true,
            columnDefs: [
                { width: "80px", targets: 0 },     // Thao tác
                { width: "100px", targets: 1 },   // Mã nhân viên
                { width: "200px", targets: 2 },   // Tên nhân viên
                { width: "100px", targets: 3 },   // Mã Khoa
                { width: "200px", targets: 4 },   // Tên Khoa
                { width: "200px", targets: 5 }    // Email
            ],
            initComplete: function () {
                // Apply the search
                this.api().columns().every(function () {
                    var that = this;
                    $('input', this.footer()).on('keyup change clear', function () {
                        if (that.search() !== this.value) {
                            that.search(this.value).draw();
                        }
                    });
                });
            }
        });

        // Initialize tooltips
        $('[data-toggle="tooltip"]').tooltip();

        // Export to Excel
        $('#btnExportExcel').click(function() {
            var table = $('#dt_member').DataTable();
            var headers = [];

            // Get headers
            $('#dt_member thead th').each(function() {
                var text = $(this).text().trim();
                if (text) {
                    headers.push(text);
                }
            });

            // Create CSV content
            var csvContent = headers.join(',') + '\n';

            // Get all data (including filtered)
            table.rows({ search: 'applied' }).every(function() {
                var rowData = [];
                this.nodes().to$().find('td').each(function(index) {
                    if (index < headers.length) {
                        var cellText = $(this).text().trim().replace(/"/g, '""');
                        rowData.push('"' + cellText + '"');
                    }
                });
                csvContent += rowData.join(',') + '\n';
            });

            // Create blob and download
            var blob = new Blob(['\ufeff' + csvContent], { type: 'text/csv;charset=utf-8;' });
            var link = document.createElement('a');
            var url = URL.createObjectURL(blob);
            link.setAttribute('href', url);
            link.setAttribute('download', 'DanhSachThanhVien_' + new Date().getTime() + '.csv');
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        });
    });

    //detele member
    $(document).on("click", ".confirm-delete", function () {
        //console.log($('#Row-' + $(this).data().email));
        //$('#Row-' + $(this).data().email).remove();
        var email = $(this).data("id");
        //var madonvi = $(this).data("donvi");
        var row = $(this).closest('tr');

        if (confirm("@SharedLocalizer["DeleteConfirm"]")) {
            $.ajax({
                url: "/API/Group/DeleteMember",
                type: "post",
                dataType: 'json',
                data: {
                    group_id: $("#group_id").val(),
                    email: email,
                    //madonvi: madonvi
                },
                success: function (result) {
                    if (result) {

                        table.row(row).remove().draw();
                    }
                }
            });
        }
    });

    $('#selMember').on('keyup', function (event) {
        // Kiểm tra mã phím Enter (keyCode là 13)
        if (event.key === "Enter" || event.keyCode === 13) {
            // Thực hiện hành động khi nhấn phím Enter
            $('.btnAdd').trigger('click');
        }
    });

    //insert member
    $(document).on("click", ".btnAdd", function () {
        var email = $('#selMember').val() + '@@tdtu.edu.vn';
        //alert(email);
        //return;

         $.ajax({
            url: "/Group/GetAllMemberUnit",
            type: "post",
            data: {
                email: email
            },
             success: function (result) {
                if (result.length == 0) {
                    $.scojs_message('@SharedLocalizer["Error"]', $.scojs_message.TYPE_ERROR);
                    return
                 }

                 $.ajax({
                            url: "/API/Group/InsertMember",
                            type: "post",
                            data: {
                                group_id: $("#group_id").val(),
                                email: email
                            },
                            dataType: 'json',
                            success: function (result) {
                                if (result === 'Exists') {
                                    alert("@SharedLocalizer["ExistedError"]");
                                    return;
                                }

                                if (result) {
                                    toastr.success("Tạo dữ liệu thành công!");
                                    window.location.reload();
                                }
                            }
                        });

    @*bootbox.prompt({
                    title: "Chọn đơn vị để phân quyền",
                    inputType: 'select',
                    inputOptions: $.map(result, function (val) { return { text: val.TenBoPhan, value: val.MaBoPhan } }),
                    callback: function (result) {
                        if (result == null) return

                        $.ajax({
                            url: "/API/Group/InsertMember",
                            type: "post",
                            data: {
                                group_id: $("#group_id").val(),
                                email: email,
                                madonvi: result
                            },
                            dataType: 'json',
                            success: function (result) {
                                if (result === 'Exists') {
                                    alert("@SharedLocalizer["ExistedError"]");
                                    return;
                                }
                                window.location.reload();
                            }
                        });
                    }
                });*@
            }
        });


    });
</script>

