                    //var tdVal = theTR.children()[i].children[0].children[0].getAttribute('value');
                    var tdVal = $(theTR.children()[i].children[0].children[0]).find('input[type="checkbox"]').val();
                
                    
                    console.log('i: ',i);
                    console.log('per: ',per);
                    console.log('tdVal: ',tdVal);
                    console.log('Number: ', Number(per - tdVal));
                    console.log("--------------------------");

                    
                    if (per - tdVal >= 0) {
                        //var ischeck = theTR.children()[i].children[0].children[0];
                        var ischeck = $(theTR.children()[i].children[0].children[0]).find('input[type="checkbox"]');
                   
                        //$(ischeck).iCheck('check');
                        //$(ischeck).iCheck('update');
